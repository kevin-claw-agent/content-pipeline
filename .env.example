# Content Pipeline Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://localhost:5432/content_pipeline
# For Docker: postgresql://content_pipeline:content_pipeline@postgres:5432/content_pipeline

# Redis Configuration
REDIS_URL=redis://localhost:6379
# For Docker: redis://redis:6379

# OpenAI API (for LLM calls)
OPENAI_API_KEY=sk-your-openai-api-key-here

# S3/MinIO Configuration
S3_ENDPOINT=http://localhost:9000
# For Docker: http://minio:9000
S3_BUCKET=content-pipeline
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# AWS Configuration (if using AWS S3 instead of MinIO)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
