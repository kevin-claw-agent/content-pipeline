# Production Environment Configuration Example
# Copy this file to .env.production and fill in your actual values

NODE_ENV=production
PORT=3000

# Production Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@your-db-host:5432/content_pipeline

# Production Redis Configuration
REDIS_URL=redis://your-redis-host:6379

# OpenAI API - Required for LLM calls
OPENAI_API_KEY=sk-your-production-api-key-here

# Production S3 Configuration
# For AWS S3:
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=your-production-bucket
S3_ACCESS_KEY=your-aws-access-key-id
S3_SECRET_KEY=your-aws-secret-access-key

# Alternative: AWS-specific settings (uncomment if using AWS)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Production specific settings
LOG_LEVEL=warn
ENABLE_DEBUG_ROUTES=false

# Monitoring (optional)
# SENTRY_DSN=your-sentry-dsn
# DATADOG_API_KEY=your-datadog-key

# Rate limiting (optional)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
